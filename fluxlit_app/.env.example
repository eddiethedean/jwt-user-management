# FluxLit entry: ``main:app`` (see ``fluxlit.toml``). Uvicorn:
#   uvicorn main:app --host 127.0.0.1 --port 8000
# Legacy alias: ``fluxlit_gateway:app`` re-exports the same ``app``.
#
# Gateway / ops (see https://fluxlit.readthedocs.io/en/stable/configuration.html):
#   FLUXLIT_TRUST_PROXY=1
#   FLUXLIT_ROOT_PATH=
#   FLUXLIT_PUBLIC_BASE_URL=http://127.0.0.1:8000
#   FLUXLIT_ENABLE_SECURITY_HEADERS=1
#   FLUXLIT_ENABLE_REQUEST_LOGGING=1
#   FLUXLIT_ENABLE_GATEWAY_ACCESS_LOG=1
#   FLUXLIT_ENABLE_GATEWAY_PROMETHEUS_METRICS=1   # requires fluxlit[metrics]
#   FLUXLIT_URL_SESSION_QUERY_PARAM=fluxlit_sid
#   FLUXLIT_STREAMLIT_PROPAGATE_REQUEST_ID=1     # X-Request-ID on ApiClient.for_fluxlit calls
#   FLUXLIT_TRACE_LOGGING=1                       # log FluxLit internal spans at DEBUG
#   FLUXLIT_DISABLE_URL_SESSION=1                 # disable fluxlit_sid URL session bridge in UI
#
# Run ``fluxlit`` from this directory or set PYTHONPATH to this directory so
# ``fluxlit doctor`` can import ``main``.

# Bundled FastAPI backend (``app/`` in this directory)
DATABASE_URL=sqlite:///./app.db
JWT_SECRET=dev-secret
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=60
PUBLIC_BASE_URL=http://127.0.0.1:8000

# Optional: directory lookup, SMTP, etc. (see app/core/config.py)
