# FluxLit entry: ``main:app`` (see ``fluxlit.toml``). Uvicorn:
#   uvicorn main:app --host 127.0.0.1 --port 8000
#
# Gateway / ops (see https://fluxlit.readthedocs.io/en/stable/configuration.html):
#   FLUXLIT_TRUST_PROXY=1
#   FLUXLIT_ROOT_PATH=
#   FLUXLIT_PUBLIC_BASE_URL=http://127.0.0.1:8000
#   FLUXLIT_DEBUG=1
#   FLUXLIT_ENABLE_SECURITY_HEADERS=1
#   FLUXLIT_URL_SESSION_QUERY_PARAM=fluxlit_sid
#
# Run ``fluxlit`` from this directory so ``fluxlit.toml`` and ``.env`` resolve.

# Copy to `.env``. Set ``DATABASE_URL``, ``JWT_*``, and ``JWT_SECRET`` here.
# Other non-sensitive defaults for the bundled FastAPI app live in `config.py` beside `app/`.

DATABASE_URL=sqlite:///./app.db
JWT_SECRET=dev-secret
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=60

# Optional overrides (defaults for ``PUBLIC_BASE_URL`` / ``BASE_PATH`` are in ``config.py``):
# PUBLIC_BASE_URL=http://127.0.0.1:8000
# BASE_PATH=

# DIRECTORY_LOOKUP_URL=
# DIRECTORY_LOOKUP_CA_BUNDLE=

# SMTP_HOST=
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM_EMAIL=
