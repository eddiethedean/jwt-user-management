ENVIRONMENT=dev
DATABASE_URL=sqlite:///./app.db
PUBLIC_BASE_URL=http://localhost:8000
DEBUG=False
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=60

# If set, allows Streamlit admin UI to call admin endpoints
ADMIN_API_KEY=change-me-too

# Optional SMTP for invites
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true

# Optional Azure AD (Microsoft Graph) validation
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
