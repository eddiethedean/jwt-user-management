# Copy to `.env` in this directory.
#
# **Secrets and deployment endpoints only** (database, JWT secret, SMTP credentials,
# directory service URL, optional CA bundle). Tunables such as ``PUBLIC_BASE_URL``,
# ``JWT_EXPIRES_MINUTES``, invite domains, cookie flags, and SMTP port/TLS defaults
# live in ``config.py`` in this directory — do not duplicate those keys here.

DATABASE_URL=sqlite:///./app.db
JWT_SECRET=dev-secret

# SMTP (optional for local dev without outbound mail)
# SMTP_HOST=
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM_EMAIL=

# Directory lookup service (optional)
# DIRECTORY_LOOKUP_URL=https://example.com/api/ldapEmail
# DIRECTORY_LOOKUP_CA_BUNDLE=/path/to/ca.pem

# Alembic / one-off seed (see README)
# SEED_ADMIN_EMAIL=
# SEED_ADMIN_PASSWORD=
