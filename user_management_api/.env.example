DATABASE_URL=sqlite:///./app.db
JWT_SECRET=dev-secret
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=60
# Optional: external path prefix when served behind a reverse proxy (e.g. Workbench)
# Example: /s/<service>/p/<project>
BASE_PATH=
PUBLIC_BASE_URL=http://127.0.0.1:8001

# Optional: auth cookie settings for HTML login session.
# When embedded in an iframe (e.g. Posit Connect), you may need:
# AUTH_COOKIE_SAMESITE=none and AUTH_COOKIE_SECURE=true
# Turn on extra cookie/path/header logging (safe: never logs token values).
COOKIE_DEBUG=false
AUTH_COOKIE_SAMESITE=lax
# Set to true/false to override scheme detection; leave blank to infer from request.
AUTH_COOKIE_SECURE=
# Optional; usually leave blank.
AUTH_COOKIE_DOMAIN=

# Optional: SMTP settings (leave unset to disable email)
SMTP_HOST=
SMTP_PORT=25
SMTP_USE_TLS=false
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

# Optional: directory lookup (cloud deployments)
# Example: https://connect.socom.mil/api/ldapEmail
DIRECTORY_LOOKUP_URL=
DIRECTORY_LOOKUP_TIMEOUT_S=5
DIRECTORY_LOOKUP_REQUIRED=false
DIRECTORY_LOOKUP_VERIFY_SSL=false
# Optional: path to CA bundle file to trust for DIRECTORY_LOOKUP_URL
DIRECTORY_LOOKUP_CA_BUNDLE=

# Optional: seed an initial admin user during `alembic upgrade head`.
# Defaults are used if these are unset.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
