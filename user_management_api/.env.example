DATABASE_URL=sqlite:///./app.db
JWT_SECRET=dev-secret
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=60
# Optional: external path prefix when served behind a reverse proxy (e.g. Workbench)
# Example: /s/<service>/p/<project>
BASE_PATH=
PUBLIC_BASE_URL=http://127.0.0.1:8001

# Optional: SMTP settings (leave unset to disable email)
SMTP_HOST=
SMTP_PORT=25
SMTP_USE_TLS=false
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

# Optional: seed an initial admin user during `alembic upgrade head`.
# Defaults are used if these are unset.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
