# Copy to `.env` in this directory.
# Set ``DATABASE_URL``, ``JWT_*``, and ``JWT_SECRET`` here (see values below for local dev).
# Other non-sensitive defaults (cookie flags, SMTP port, directory timeouts, ``BASE_PATH``,
# ``PUBLIC_BASE_URL``, etc.) live in `config.py` beside `app/`.

DATABASE_URL=sqlite:///./app.db
JWT_SECRET=dev-secret
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=60

# --- Optional overrides (uncomment if you differ from `config.py` / above) ---

# PUBLIC_BASE_URL=http://127.0.0.1:8001
# BASE_PATH=

# AUTH_COOKIE_SECURE=true
# AUTH_COOKIE_SAMESITE=none
# COOKIE_DEBUG=true

# SMTP_HOST=
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM_EMAIL=

# DIRECTORY_LOOKUP_URL=https://example.com/api/ldapEmail
# DIRECTORY_LOOKUP_CA_BUNDLE=/path/to/ca.pem

# SEED_ADMIN_EMAIL=
# SEED_ADMIN_PASSWORD=
