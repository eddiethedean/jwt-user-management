ENVIRONMENT=dev
DATABASE_URL=sqlite:///./app.db
PUBLIC_BASE_URL=http://localhost:8000
DEBUG=False
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=60

# If set, allows Streamlit admin UI to call admin endpoints
ADMIN_API_KEY=change-me-too

# Optional: protect the embedded admin UI at /admin/* behind an admin JWT
# (HTTP + websocket). Enable in prod.
ADMIN_UI_REQUIRE_JWT=

# Optional: embedded Streamlit admin subprocess behavior
ADMIN_UI_INTERNAL_PORT=
ADMIN_UI_LOG_FILE=
ADMIN_UI_READY_WAIT_S=

# Optional seed user (applied by Alembic migration on `alembic upgrade head`).
# If the email already exists, the migration does nothing.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_FULL_NAME=

# Optional SMTP for invites
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true

# Optional Azure AD (Microsoft Graph) validation
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
